{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "regions": ["fra1"],
  "functions": {
    "src/app/api/reports/*/generate-pdf/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/export/generate-pdf/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/intake/process/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/cases/*/exports/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/exports/*/generate/route.ts": {
      "maxDuration": 60
    }
  }
}
