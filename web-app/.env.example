# ─── REQUIRED — Supabase ─────────────────────────────────────────────────────
# Supabase project URL (from Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Supabase anon (public) key — safe to expose to client
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase service role key — SERVER-SIDE ONLY, never expose to client
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── REQUIRED — App URL ───────────────────────────────────────────────────────
# Your deployed app URL (used for email links and OAuth redirects)
NEXT_PUBLIC_APP_URL=https://app.refrag.com

# ─── OPTIONAL — Email Delivery ────────────────────────────────────────────────
# Resend API key — obtain at https://resend.com
# Without this: email delivery runs in dry-run mode (logged but not sent)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# From address for outgoing emails — must be a verified domain in Resend
RESEND_FROM_EMAIL=reports@yourdomain.com

# ─── OPTIONAL — AI Report Drafting ───────────────────────────────────────────
# OpenAI API key — obtain at https://platform.openai.com
# Without this: AI draft buttons show a placeholder response
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxx

# ─── OPTIONAL — OCR (Document Extraction) ─────────────────────────────────────
# Google Cloud Vision API key — simplest option for server-side OCR
# Without this: OCR falls back to pdf-parse/mammoth for documents, stub for images
# Obtain: https://console.cloud.google.com > APIs & Services > Credentials
GOOGLE_VISION_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxx

# Google Cloud Vision service account JSON credentials (alternative to API key above)
# Without this: OCR is skipped, manual entry is used instead
# Obtain: https://console.cloud.google.com > Service Accounts > Create Key (JSON)
# Option 1: Paste the full service account JSON as a single-line string
GOOGLE_CLOUD_VISION_CREDENTIALS={"type":"service_account","project_id":"...","private_key":"..."}
# Option 2: Path to the service account JSON file on disk
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ─── OPTIONAL — PDF Generation ────────────────────────────────────────────────
# For Vercel deployment: leave this unset — @sparticuz/chromium is used automatically
# For local/self-hosted: set to your Chromium executable path
PLAYWRIGHT_EXECUTABLE_PATH=/usr/bin/chromium
# or on macOS: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# ─── OPTIONAL — Stripe Billing ────────────────────────────────────────────────
# Without this: billing features are disabled (no credit gates)
# Stripe secret key — obtain at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
# Stripe webhook secret — from stripe listen output or Stripe Dashboard > Webhooks
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
# Price IDs for credit packs — create in Stripe Dashboard > Products
STRIPE_PRICE_ID_CREDITS_5=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ID_CREDITS_20=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ID_CREDITS_50=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ID_CREDITS_100=price_xxxxxxxxxxxxxxxxxxxx

# ─── OPTIONAL — Google Maps ───────────────────────────────────────────────────
# Without this: location fields use plain text inputs (no autocomplete)
# Enable Maps JavaScript API and Places API in Google Cloud Console
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxx

# ─── OPTIONAL — Inbound Email ─────────────────────────────────────────────────
# Shared secret for email ingestion webhook endpoint
INBOUND_EMAIL_SECRET=your_webhook_secret_here
