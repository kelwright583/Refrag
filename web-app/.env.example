# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Resend — transactional email (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=notifications@yourdomain.com

# OpenAI — used for document ingestion field extraction
OPENAI_API_KEY=sk-xxxxxxxxxxxx

# Google Cloud Vision — OCR on assessment tab drop zones
# Option 1: Paste the full service account JSON as a single-line string
GOOGLE_CLOUD_VISION_CREDENTIALS={"type":"service_account","project_id":"...","private_key":"..."}
# Option 2: Path to the service account JSON file on disk
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Google Maps — address autocomplete and map previews
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Inbound email webhook — shared secret for email ingestion endpoint
INBOUND_EMAIL_SECRET=your_webhook_secret_here

# Mock mode — set to "true" to use mock data without Supabase
# NEXT_PUBLIC_USE_MOCK=false
